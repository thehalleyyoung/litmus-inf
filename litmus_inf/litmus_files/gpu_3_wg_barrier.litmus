C gpu_3_wg_barrier

{ int x=0; int y=0; int z=0; }

P0(
  int* x, int* y
) {
  WRITE_ONCE(*x, 1);
  smp_mb();
  WRITE_ONCE(*y, 1);
}

P1(
  int* y, int* z
) {
  int r0 = READ_ONCE(*y);
  smp_mb();
  WRITE_ONCE(*z, 1);
}

P2(
  int* x, int* z
) {
  int r1 = READ_ONCE(*z);
  smp_mb();
  int r2 = READ_ONCE(*x);
}

exists (1:r0=1 /\ 2:r1=1 /\ 2:r2=0)