C gpu_iriw_dev

{ int x=0; int y=0; }

P0(
  int* x
) {
  WRITE_ONCE(*x, 1);
}

P1(
  int* y
) {
  WRITE_ONCE(*y, 1);
}

P2(
  int* x, int* y
) {
  int r0 = READ_ONCE(*x);
  smp_mb();
  int r1 = READ_ONCE(*y);
}

P3(
  int* x, int* y
) {
  int r2 = READ_ONCE(*y);
  smp_mb();
  int r3 = READ_ONCE(*x);
}

exists (2:r0=1 /\ 2:r1=0 /\ 3:r2=1 /\ 3:r3=0)