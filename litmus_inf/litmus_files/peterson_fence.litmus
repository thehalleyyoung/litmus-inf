C peterson_fence

{ int x=0; int y=0; int z=0; }

P0(
  int* x, int* y, int* z
) {
  WRITE_ONCE(*x, 1);
  smp_mb();
  WRITE_ONCE(*z, 1);
  smp_mb();
  int r0 = READ_ONCE(*y);
  int r1 = READ_ONCE(*z);
}

P1(
  int* x, int* y, int* z
) {
  WRITE_ONCE(*y, 1);
  smp_mb();
  WRITE_ONCE(*z, 2);
  smp_mb();
  int r2 = READ_ONCE(*x);
  int r3 = READ_ONCE(*z);
}

exists (0:r0=0 /\ 1:r2=0)