C mca_store_atom

{ int x=0; }

P0(
  int* x
) {
  WRITE_ONCE(*x, 1);
}

P1(
  int* x
) {
  WRITE_ONCE(*x, 2);
}

P2(
  int* x
) {
  int r0 = READ_ONCE(*x);
  int r1 = READ_ONCE(*x);
}

P3(
  int* x
) {
  int r2 = READ_ONCE(*x);
  int r3 = READ_ONCE(*x);
}

exists (2:r0=1 /\ 2:r1=2 /\ 3:r2=2 /\ 3:r3=1)