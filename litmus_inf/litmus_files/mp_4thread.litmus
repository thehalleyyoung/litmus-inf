C mp_4thread

{ int x=0; int y=0; int z=0; }

P0(
  int* x
) {
  WRITE_ONCE(*x, 1);
}

P1(
  int* y
) {
  WRITE_ONCE(*y, 1);
}

P2(
  int* y, int* z
) {
  int r0 = READ_ONCE(*y);
  WRITE_ONCE(*z, 1);
}

P3(
  int* x, int* z
) {
  int r1 = READ_ONCE(*z);
  int r2 = READ_ONCE(*x);
}

exists (2:r0=1 /\ 3:r1=1 /\ 3:r2=0)