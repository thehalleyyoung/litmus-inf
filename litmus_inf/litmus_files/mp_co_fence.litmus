C mp_co_fence

{ int x=0; int y=0; }

P0(
  int* x, int* y
) {
  WRITE_ONCE(*x, 1);
  smp_mb();
  WRITE_ONCE(*y, 1);
}

P1(
  int* x, int* y
) {
  WRITE_ONCE(*x, 2);
  smp_mb();
  int r0 = READ_ONCE(*y);
}

P2(
  int* x, int* y
) {
  int r1 = READ_ONCE(*y);
  smp_mb();
  int r2 = READ_ONCE(*x);
}

exists (2:r1=1 /\ 2:r2=0)