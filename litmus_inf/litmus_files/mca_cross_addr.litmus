C mca_cross_addr

{ int x=0; int y=0; }

P0(
  int* x, int* y
) {
  WRITE_ONCE(*x, 1);
  WRITE_ONCE(*y, 1);
}

P1(
  int* x, int* y
) {
  int r0 = READ_ONCE(*y);
  int r1 = READ_ONCE(*x);
}

P2(
  int* x, int* y
) {
  int r2 = READ_ONCE(*x);
  int r3 = READ_ONCE(*y);
}

exists (1:r0=1 /\ 1:r1=0 /\ 2:r2=1 /\ 2:r3=0)