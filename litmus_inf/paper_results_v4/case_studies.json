{
  "spsc_queue_mp": {
    "description": "Lock-free SPSC queue (message-passing pattern) ported from x86 to ARM/RISC-V",
    "pattern": "mp",
    "source": "x86",
    "results": [
      {
        "target": "x86",
        "safe": true,
        "fence_fix": null
      },
      {
        "target": "sparc",
        "safe": false,
        "fence_fix": "membar #StoreStore|#LoadLoad"
      },
      {
        "target": "arm",
        "safe": false,
        "fence_fix": "dmb ishst (T0); dmb ishld (T1)"
      },
      {
        "target": "riscv",
        "safe": false,
        "fence_fix": "fence w,w (T0); fence r,r (T1)"
      },
      {
        "target": "opencl_wg",
        "safe": false,
        "fence_fix": "work_group_barrier(CLK_GLOBAL_MEM_FENCE)"
      },
      {
        "target": "opencl_dev",
        "safe": false,
        "fence_fix": "atomic_work_item_fence(CLK_GLOBAL_MEM_FENCE, memory_order_acq_rel, memory_scope_device)"
      },
      {
        "target": "vulkan_wg",
        "safe": false,
        "fence_fix": "work_group_barrier(CLK_GLOBAL_MEM_FENCE)"
      },
      {
        "target": "vulkan_dev",
        "safe": false,
        "fence_fix": "atomic_work_item_fence(CLK_GLOBAL_MEM_FENCE, memory_order_acq_rel, memory_scope_device)"
      },
      {
        "target": "ptx_cta",
        "safe": false,
        "fence_fix": "membar.cta"
      },
      {
        "target": "ptx_gpu",
        "safe": false,
        "fence_fix": "membar.gl"
      }
    ],
    "finding": "Pattern safe on x86 (TSO stores ordered), UNSAFE on ARM/RISC-V (no store-store ordering). Fix: add dmb ishst on ARM, fence w,w on RISC-V."
  },
